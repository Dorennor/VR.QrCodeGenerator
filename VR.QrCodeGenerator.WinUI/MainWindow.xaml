<Window
    x:Class="VR.QrCodeGenerator.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VR.QrCodeHelper.WinUI">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Default">
                        <StaticResource x:Key="SystemControlHighlightAccentBrush" ResourceKey="VsAccessAccentBrush" />
                        <SolidColorBrush x:Key="TextControlElevationBorderFocusedBrush" Color="#5D5691" />
                        <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#5D5691" />

                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#5D5691" />
                        <SolidColorBrush x:Key="TextControlBoxFocusVisualBrush" Color="#5D5691" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>

                <SolidColorBrush x:Key="VsAccessAccentBrush" Color="#5D5691" />
            </ResourceDictionary>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.RowSpan="2"
                BorderBrush="{StaticResource VsAccessAccentBrush}"
                BorderThickness="1"
                Canvas.ZIndex="999"
                IsHitTestVisible="False" />

        <Grid x:Name="AppTitleBar" Grid.Row="0" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="QR Code Generator"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontSize="12" Opacity="0.8" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">

                <Button Click="Minimize_OnClick" Background="Transparent" BorderThickness="0" Width="46" Height="32" Padding="0">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE921;" FontSize="10" />
                </Button>

                <Button x:Name="MaximizeButton" Click="Maximize_OnClick" Background="Transparent" BorderThickness="0" Width="46" Height="32" Padding="0">
                    <FontIcon x:Name="MaximizeIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE922;" FontSize="10" />
                </Button>

                <Button Click="Close_OnClick" Background="Transparent" BorderThickness="0" Width="46" Height="32" Padding="0">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E81123" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                    </Button.Resources>
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8BB;" FontSize="10" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Grid.Row="0"
                    BorderBrush="{ThemeResource VsAccessAccentBrush}"
                    BorderThickness="1,1,0.5,0.5">
                <TextBox Name="UrlTextBox" FontSize="14" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                         Margin="10, 10, 5, 10" Padding="3" TextChanged="UrlTextBox_OnTextChanged" />
            </Border>

            <Border Grid.Column="1" Grid.Row="0"
                    BorderBrush="{ThemeResource VsAccessAccentBrush}"
                    BorderThickness="0.5,1,1,0.5">
                <Button Name="GenerateQrCode" Click="GenerateQrCode_OnClick" Content="Generate QR code" FontSize="14"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="5, 10, 10, 10" Padding="5" />
            </Border>

            <Border Grid.Column="0" Grid.Row="1"
                    BorderBrush="{ThemeResource VsAccessAccentBrush}"
                    BorderThickness="1,0.5,0.5,1">
                <Image x:Name="QrCodeImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="10, 10, 10, 10" />
            </Border>

            <Border Grid.Column="1" Grid.Row="1"
                    BorderBrush="{ThemeResource VsAccessAccentBrush}"
                    BorderThickness="0.5,0.5,1,1">
                <Button Name="TEST"  Content="TEEEEEEEEEEEEEEEST" FontSize="14"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="5, 10, 10, 10" Padding="5" />
            </Border>
        </Grid>
    </Grid>
</Window>