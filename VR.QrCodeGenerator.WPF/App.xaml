<Application x:Class="VR.QrCodeGenerator.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="VsAccessAccentBrush" Color="#5D5691" />

            <Color x:Key="SystemAccentColor">#5D5691</Color>
            <SolidColorBrush x:Key="SystemAccentBrush" Color="#5D5691" />

            <StaticResource x:Key="SystemControlHighlightAccentBrush" ResourceKey="VsAccessAccentBrush" />
            <SolidColorBrush x:Key="TextControlElevationBorderFocusedBrush" Color="#5D5691" />
            <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#5D5691" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#5D5691" />
            <SolidColorBrush x:Key="TextControlBoxFocusVisualBrush" Color="#5D5691" />

            <SolidColorBrush x:Key="SliderTrackValueFillBrush" Color="#5D5691" />
            <SolidColorBrush x:Key="SliderThumbFillBrush" Color="#5D5691" />
            <SolidColorBrush x:Key="SliderThumbFillBrushPointerOver" Color="#6D66A1" />

            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="BorderBrush" Value="{StaticResource VsAccessAccentBrush}" />
                <Setter Property="CaretBrush" Value="{StaticResource VsAccessAccentBrush}" />
                <Setter Property="Padding" Value="3" />
            </Style>

            <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="BorderBrush" Value="{StaticResource VsAccessAccentBrush}" />
                <Setter Property="Padding" Value="2" />
            </Style>

            <Style TargetType="ComboBoxItem">
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" UseLayoutRounding="True">
                                <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Rectangle x:Name="AccentBar" Width="6" HorizontalAlignment="Left" Fill="Transparent"
                                               RadiusX="2" RadiusY="2" Grid.Column="0" Margin="2,4" />

                                    <ContentPresenter x:Name="ContentPresenter" Grid.Column="1"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      Margin="8,4,6,4" VerticalAlignment="Center" />
                                </Grid>

                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#333333" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="AccentBar" Storyboard.TargetProperty="Fill">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource VsAccessAccentBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#2C2C2C" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="White" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>