<ui:FluentWindow x:Class="VR.QrCodeGenerator.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="QR Code Generator" Height="700" Width="1100"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        BorderBrush="#5D5691"
        BorderThickness="2">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="QR Code Generator" />

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#5D5691" BorderThickness="1" CornerRadius="4">
                    <ui:TextBox Name="UrlTextBox" Margin="10" 
                                PlaceholderText="Enter URL..." FontSize="14" 
                                TextChanged="UrlTextBox_OnTextChanged" />
                </Border>

                <Border Grid.Row="1" Margin="0,15,0,0" BorderBrush="#5D5691" BorderThickness="1" CornerRadius="4">
                    <WrapPanel Margin="10">
                        <ui:Button Name="GenerateQrCodeButton" Content="Generate QR" 
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Background="#5D5691" BorderBrush="#5D5691"
                                   MouseOverBackground="#6D66A1" PressedBackground="#4D4681"
                                   Click="GenerateQrCodeButton_OnClick" Margin="0,0,10,0" />

                        <ui:Button Name="CopyToClipboardButton" Content="Copy Image" 
                                   Icon="{ui:SymbolIcon Copy24}"
                                   Click="CopyToClipboardButton_OnClick" Margin="0,0,10,0"/>

                        <ui:Button Name="ResetQrCodeButton" Content="Reset" 
                                   Icon="{ui:SymbolIcon Delete24}" Appearance="Danger"
                                   Click="ResetQrCodeButton_OnClick" />
                    </WrapPanel>
                </Border>

                <Border Grid.Row="2" Margin="0,15,0,0" BorderBrush="#5D5691" BorderThickness="1" CornerRadius="4">
                    <Image x:Name="QrCodeImage" Stretch="Uniform" Margin="20"/>
                </Border>
            </Grid>

            <Border Grid.Column="1" Padding="15" BorderBrush="#5D5691" BorderThickness="1" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MinWidth="240">

                        <ui:TextBlock Text="Content Settings" FontTypography="Subtitle" Margin="0,0,0,10"/>
                        <Border Padding="10" BorderBrush="#5D5691" BorderThickness="1" CornerRadius="4" Margin="0,0,0,20">
                            <StackPanel>
                                <ui:TextBlock Text="Content Type:" Appearance="Secondary" Margin="0,0,0,5"/>
                                <ComboBox Name="ContentOptionsComboBox" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>

                        <ui:TextBlock Text="Appearance" FontTypography="Subtitle" Margin="0,0,0,10"/>
                        <Border Padding="10" BorderBrush="#5D5691" BorderThickness="1" CornerRadius="4" Margin="0,0,0,20">
                            <StackPanel>

                                <ui:TextBlock Text="Error Correction:" Appearance="Secondary" Margin="0,0,0,5"/>
                                <ComboBox Name="EccComboBox" HorizontalAlignment="Stretch" SelectedIndex="2" Margin="0,0,0,15">
                                    <ComboBoxItem Content="Low (7%)" Tag="L" />
                                    <ComboBoxItem Content="Medium (15%)" Tag="M" />
                                    <ComboBoxItem Content="Quality (25%)" IsSelected="True" Tag="Q" />
                                    <ComboBoxItem Content="High (30%)" Tag="H" />
                                </ComboBox>

                                <Grid Margin="0,0,0,5">
                                    <ui:TextBlock Text="Pixel Size:" Appearance="Secondary"/>
                                    <ui:TextBlock Text="{Binding ElementName=PixelSizeSlider, Path=Value, StringFormat=N0}" 
                                                  HorizontalAlignment="Right" Appearance="Secondary"/>
                                </Grid>

                                <Slider Name="PixelSizeSlider" Maximum="50" Minimum="1" Value="20" 
                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,15"/>

                                <ui:TextBlock Text="Colors:" Appearance="Secondary" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Code" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                        <xctk:ColorPicker x:Name="FgColorPicker" 
                                                          Background="White"
                                                          Foreground="Black"
                                                          BorderBrush="#5D5691"
                                                          SelectedColor="Black"
                                                          DisplayColorAndName="True" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Background" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                        <xctk:ColorPicker x:Name="BgColorPicker" 
                                                          Background="White"
                                                          Foreground="Black"
                                                          BorderBrush="#5D5691"
                                                          SelectedColor="White"
                                                          DisplayColorAndName="True" />
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <ui:TextBlock Text="Output Settings" FontTypography="Subtitle" Margin="0,0,0,10"/>
                        <Border Padding="10" BorderBrush="#5D5691" BorderThickness="1" CornerRadius="4">
                            <StackPanel>
                                <ui:TextBlock Text="Extension:" Appearance="Secondary" Margin="0,0,0,5"/>
                                <ComboBox Name="FileFormatOptionsComboBox" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>