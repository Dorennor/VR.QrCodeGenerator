<Window x:Class="VR.QrCodeGenerator.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="QR Code Generator" Height="600" Width="1000"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStyle="None" ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Style/CustomeStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Height="36" BorderBrush="{StaticResource BorderBrushCustom}" BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="QR Code Generator" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource AccentTextBrush}" />

                <!-- Draggable area -->
                <Border Grid.Column="1" Background="Transparent" MouseDown="TitleBar_OnMouseDown" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton" Width="34" Height="24" Click="MinimizeButton_OnClick" Content="_" ToolTip="Minimize" Margin="4,0" />
                    <Button x:Name="MaxRestoreButton" Width="34" Height="24" Click="MaxRestoreButton_OnClick" Content="▢" ToolTip="Maximize" Margin="4,0" />
                    <Button x:Name="CloseButton" Width="34" Height="24" Click="CloseButton_OnClick" Content="X" ToolTip="Close" Margin="4,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
                <TextBox Name="UrlTextBox" Margin="10,10,5,10" Padding="3" HorizontalAlignment="Stretch" VerticalAlignment="Center" FontSize="14" TextChanged="UrlTextBox_OnTextChanged" />
            </Border>

            <Border Grid.Row="0" Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Button Name="GenerateQrCodeButton" Margin="10,10,5,10" Padding="5" HorizontalAlignment="Center" VerticalAlignment="Center" Click="GenerateQrCodeButton_OnClick" Content="Generate QR code" FontSize="14" />
                    <Button Name="CopyToClipboardButton" Margin="5,10,5,10" Padding="5" HorizontalAlignment="Center" VerticalAlignment="Center" Click="CopyToClipboardButton_OnClick" Content="Copy QR code to clipboard" FontSize="14" />
                    <Button Name="ResetQrCodeButton" Margin="5,10,5,10" Padding="5" HorizontalAlignment="Center" VerticalAlignment="Center" Click="ResetQrCodeButton_OnClick" Content="Reset QR code" FontSize="14" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
                <Image x:Name="QrCodeImage" Margin="10,10,10,10" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" />
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Padding="15" BorderBrush="Gray" BorderThickness="1">
                <StackPanel MinWidth="220" Orientation="Vertical">
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Content Settings" />
                        <Border Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                            <StackPanel>
                                <TextBlock FontSize="12" Opacity="0.7" Text="Content Type:" />
                                <ComboBox Name="ContentOptionsComboBox" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Appearance" />
                        <Border Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock FontSize="12" Opacity="0.7" Text="Redundancy (Error Correction):" />
                                    <ComboBox Name="EccComboBox" HorizontalAlignment="Stretch" SelectedIndex="2">
                                        <ComboBoxItem Content="Low (7%)" Tag="L" />
                                        <ComboBoxItem Content="Medium (15%)" Tag="M" />
                                        <ComboBoxItem Content="Quality (25%)" IsSelected="True" Tag="Q" />
                                        <ComboBoxItem Content="High (30%)" Tag="H" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock FontSize="12" Opacity="0.7" Text="Pixel Size:" />
                                        <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.7" Text="{Binding ElementName=PixelSizeSlider, Path=Value}" />
                                    </Grid>
                                    <Slider Name="PixelSizeSlider" Maximum="50" Minimum="1" TickFrequency="1" Value="20" IsSnapToTickEnabled="True" />
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock FontSize="12" Opacity="0.7" Text="Colors:" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock HorizontalAlignment="Center" FontSize="10" Opacity="0.6" Text="Code" />
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                                                <ToggleButton x:Name="FgColorButton"
                                                              Width="150" Height="40" />

                                                <Popup IsOpen="{Binding IsChecked, ElementName=FgColorButton}"
                                                       PlacementTarget="{Binding ElementName=FgColorButton}"
                                                       Placement="Bottom"
                                                       StaysOpen="False"
                                                       AllowsTransparency="True">

                                                    <Border Background="White"
                                                            BorderBrush="LightGray"
                                                            BorderThickness="1"
                                                            Padding="10"
                                                            CornerRadius="8">
                                                        <StackPanel>
                                                            <TextBlock Text="Choose a Color" Margin="0,0,0,10" FontWeight="SemiBold" />

                                                            <xctk:ColorPicker x:Name="FgColorPicker"
                                                                              Width="220"
                                                                              SelectedColor="Black"
                                                                              DisplayColorAndName="True"
                                                                              SelectedColorChanged="FgColorPicker_OnSelectedColorChanged" />

                                                            <Button x:Name="FgColorPickerClose"
                                                                    Content="OK"
                                                                    Margin="0,10,0,0"
                                                                    Click="FgColorPickerClose_OnClick" />
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock HorizontalAlignment="Center" FontSize="10" Opacity="0.6" Text="Back" />
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                                                <ToggleButton x:Name="BgColorButton"
                                                              Width="150" Height="40" />

                                                <Popup IsOpen="{Binding IsChecked, ElementName=BgColorButton}"
                                                       PlacementTarget="{Binding ElementName=BgColorButton}"
                                                       Placement="Bottom"
                                                       StaysOpen="False"
                                                       AllowsTransparency="True">

                                                    <Border Background="White"
                                                            BorderBrush="LightGray"
                                                            BorderThickness="1"
                                                            Padding="10"
                                                            CornerRadius="8">
                                                        <StackPanel>
                                                            <TextBlock Text="Choose a Color" Margin="0,0,0,10" FontWeight="SemiBold" />

                                                            <xctk:ColorPicker x:Name="BgColorPicker"
                                                                              Width="220"
                                                                              SelectedColor="White"
                                                                              DisplayColorAndName="True"
                                                                              SelectedColorChanged="BgColorPicker_OnSelectedColorChangedColorPicker_OnSelectedColorChanged" />

                                                            <Button x:Name="BgColorPickerClose"
                                                                    Content="OK"
                                                                    Margin="0,10,0,0"
                                                                    Click="BgColorPickerClose_OnClick" />
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Output Format" />
                        <Border Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                            <StackPanel>
                                <TextBlock FontSize="12" Opacity="0.7" Text="Extension:" />
                                <ComboBox Name="FileFormatOptionsComboBox" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>